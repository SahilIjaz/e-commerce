{
  "name": "ecommerce/backend",
  "description": "E-Commerce Platform Backend",
  "type": "project",
  "require": {
    "php": "^8.0",
    "firebase/php-jwt": "^5.0",
    "vlucas/phpdotenv": "^5.4",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t public",
    "test": "phpunit"
  }
}
